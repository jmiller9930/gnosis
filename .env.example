# Copy to `.env` in the repo root (do not commit `.env`).
# Used by docker compose for Postgres, app, and optional Redis.

# --- Postgres (db service) ---
POSTGRES_USER=gnosis
POSTGRES_PASSWORD=gnosis
POSTGRES_DB=gnosis
# Host port mapping (avoid clash with a local Postgres)
POSTGRES_PORT=5432

# --- App ---
# Default matches db service credentials above.
DATABASE_URL=postgresql://gnosis:gnosis@db:5432/gnosis

# Optional: when using `docker compose --profile with-redis up`
REDIS_URL=
# REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
